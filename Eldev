; -*- mode: emacs-lisp; lexical-binding: t -*-

;; Eldev configuration for ox-zola

(eldev-use-package-archive 'melpa)
(eldev-use-package-archive 'gnu)

;; ox-hugo (and its transitive dep tomelr) for tests
(eldev-add-extra-dependencies 'test '(:package ox-hugo))

;; Main project files
(setf eldev-main-fileset '("ox-zola.el" "ox-zola-dev.el"))

;; Test files
(setf eldev-test-fileset '("test/ox-zola-test.el" "test/ox-zola-full-test.el"))

;; Clean build directory
(defun eldev-clean-build ()
  "Clean the build directory."
  (let ((build-dir (expand-file-name "build" eldev-project-dir)))
    (when (file-directory-p build-dir)
      (delete-directory build-dir t)
      (message "Cleaned %s" build-dir))))
